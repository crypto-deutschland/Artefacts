                )}
              </>
            ) : (
              // Quiz Done
              <div style={{ textAlign: "center", padding: "40px 20px" }}>
                <div style={{ fontSize: 64, marginBottom: 16 }}>
                  {quizScore >= quizTerms.length * 0.8 ? "🏆" : quizScore >= quizTerms.length * 0.5 ? "🌕" : "📚"}
                </div>
                <div style={{ fontWeight: 800, fontSize: 28, marginBottom: 8 }}>
                  {quizScore} / {quizTerms.length}
                </div>
                <div style={{ color: "#9a8a7a", marginBottom: 8, fontSize: 15 }}>
                  {quizScore >= quizTerms.length * 0.8 ? "Absoluter Krypto-Profi! 🚀" :
                    quizScore >= quizTerms.length * 0.5 ? "Guter Ansatz – weiter so! 💪" : "Noch etwas üben – du schaffst das! 📖"}
                </div>
                <div style={{ fontFamily: "'IBM Plex Mono'", fontSize: 11, color: "#5a5050", marginBottom: 32, letterSpacing: 1 }}>
                  {Math.round((quizScore / quizTerms.length) * 100)}% RICHTIG
                </div>
                <div style={{ display: "flex", gap: 12, justifyContent: "center", flexWrap: "wrap" }}>
                  <button className="mode-btn" style={{ padding: "14px 24px", fontSize: 14, borderColor: "rgba(240,165,0,0.4)" }} onClick={shareResult}>
                    {shareCopied ? "✅ Kopiert!" : "📤 Teilen"}
                  </button>
                  <button className="mode-btn" style={{ padding: "14px 24px", fontSize: 14 }} onClick={startQuiz}>
                    🔄 Nochmal
                  </button>
                  <button className="mode-btn" style={{ padding: "14px 24px", fontSize: 14 }} onClick={() => setMode("home")}>
                    📚 Glossar
                  </button>
                </div>
              </div>
            )}
          </>
        )}

      </div>
    </div>
  );
}
