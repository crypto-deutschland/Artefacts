  { id: 56, term: "Ethereum (ETH)", short: "Die Smart-Contract-Blockchain", explanation: "Die zweitgrößte Kryptowährung. Ethereum ermöglicht Smart Contracts und ist die Basis für DeFi, NFTs und tausende Projekte.", emoji: "Ξ", category: "Basics" },
  { id: 57, term: "Consensus Mechanism", short: "Wie die Blockchain Einigkeit erzielt", explanation: "Das Verfahren, mit dem alle Netzwerkteilnehmer einer Blockchain übereinstimmen. Bekannte Varianten: Proof of Work und Proof of Stake.", emoji: "🤝", category: "Technik" },
