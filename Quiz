function generateQuizQuestion(terms, currentTerm) {
  const wrongTerms = terms.filter(t => t.id !== currentTerm.id);
  const shuffled = wrongTerms.sort(() => Math.random() - 0.5).slice(0, 3);
  const options = [...shuffled, currentTerm].sort(() => Math.random() - 0.5);
  return {
    question: currentTerm.short,
    correct: currentTerm.term,
    options: options.map(t => t.term),
    emoji: currentTerm.emoji,
  };
}

