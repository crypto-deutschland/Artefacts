  { id: 59, term: "Proof of Stake (PoS)", short: "Konsens durch hinterlegte Coins", explanation: "Validatoren hinterlegen Coins als Sicherheit und bestätigen Transaktionen. Energieeffizienter als Proof of Work.", emoji: "🏅", category: "Technik" },
