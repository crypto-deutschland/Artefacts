  { id: 79, term: "Interoperabilität", short: "Blockchains kommunizieren miteinander", explanation: "Die Fähigkeit verschiedener Blockchains, miteinander zu interagieren. Eines der großen Ziele der Krypto-Industrie.", emoji: "🔗", category: "Technik" },
